{
  "name": "MCurio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc && cross-env NODE_OPTIONS=--max_old_space_size=4096 refine build",
    "codegen": "graphql-codegen",
    "dev": "refine dev",
    "format": "prettier --write src",
    "lint": "eslint src --fix",
    "refine": "refine",
    "seed:snaplet:sync": "npx @snaplet/seed sync --config seed.config.ts",
    "seed:snaplet:generate": "npx @snaplet/seed generate --config seed.config.ts",
    "seed:auth:users": "bash ./scripts/seed-auth-users.sh",
    "seed:snaplet:reset": "supabase db reset && npm run seed:snaplet:sync && npm run seed:auth:users",
    "start": "refine start",
    "test": "vitest",
    "supabase:restart": "supabase stop && supabase start",
    "supabase:start:fast": "supabase start -x logflare,vector,imgproxy,studio,mailpit"
  },
  "dependencies": {
    "@ant-design/cssinjs": "^1.17.2",
    "@ant-design/icons": "^5.5.1",
    "@ant-design/plots": "^1.2.5",
    "@dnd-kit/core": "^6.0.8",
    "@dnd-kit/modifiers": "^6.0.1",
    "@dnd-kit/sortable": "^7.0.2",
    "@refinedev/antd": "^5.47.0",
    "@refinedev/cli": "^2.16.51",
    "@refinedev/core": "^4.58.0",
    "@refinedev/devtools": "^1.2.17",
    "@refinedev/nestjs-query": "^1.3.5",
    "@refinedev/react-router": "^1.0.1",
    "@supabase/supabase-js": "^2.99.1",
    "@uiw/react-md-editor": "^3.19.5",
    "antd": "^5.17.0",
    "apollo-server": "^3.13.0",
    "classnames": "^2.3.2",
    "cross-env": "^7.0.3",
    "dayjs": "^1.10.7",
    "graphql": "^15.10.1",
    "graphql-tag": "^2.12.6",
    "graphql-ws": "^5.9.1",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-icons": "^5.6.0",
    "react-router": "^7.0.2"
  },
  "devDependencies": {
    "@snaplet/seed": "^0.98.0",
    "@graphql-codegen/cli": "^5.0.0",
    "@graphql-codegen/import-types-preset": "^3.0.0",
    "@graphql-codegen/typescript": "^4.0.1",
    "@graphql-codegen/typescript-operations": "^4.0.1",
    "@types/node": "^18.16.2",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@typescript-eslint/parser": "5.48.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/ui": "^4.1.0",
    "autoprefixer": "^10.4.1",
    "cross-env": "^7.0.3",
    "eslint": "^8.24.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-simple-import-sort": "^10.0.0",
    "jsdom": "^29.0.0",
    "postcss": "^8.1.4",
    "postcss-nesting": "^12.0.1",
    "prettier": "^2.7.1",
    "postgres": "^3.4.5",
    "supabase": "^2.83.0",
    "typescript": "^5.4.2",
    "vite": "^5.4.15",
    "vite-tsconfig-paths": "^4.2.1",
    "vitest": "^4.1.0"
  }
}